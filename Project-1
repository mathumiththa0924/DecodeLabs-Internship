        <div class="testimonial-author">
          <div class="avatar">👩</div>
          <div>
            <div class="author-name">Zara Mendis</div>
            <div class="author-role">Graduate Student</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section" id="visit">
    <h2>Come Say Hello ☕</h2>
    <p>Open daily from 7 AM to 9 PM. Located in the heart of the city — we saved you a table.</p>
    <a href="#" class="cta-btn">Get Directions →</a>
  </section>

